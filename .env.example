# Copy this file to .env and fill in your values.
# .env is in .gitignore – never commit real keys.
#
# On Raspberry Pi: copy to .env on the Pi and use Linux paths, e.g.:
#   YT_COOKIES_FILE=/home/pi/tres-robo/cookies.txt

# Required for LLM (OpenAI)
OPENAI_API_KEY=

# TTS: google (oletus, ilmainen) tai elevenlabs
# TTS_PROVIDER=google

# Optional: ElevenLabs (kun TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Optional: YouTube Premium – path to cookies.txt (export from browser)
# Windows: YT_COOKIES_FILE=c:\path\to\Tres-Robo\cookies.txt
# Raspberry Pi: YT_COOKIES_FILE=/home/pi/tres-robo/cookies.txt
YT_COOKIES_FILE=

# Optional: 4-array microphone (ReSpeaker etc.)
# MIC_DEVICE=hw:2,0
# MIC_CHANNELS=4
# MIC_SAMPLE_RATE=16000
# USE_DENOISER=0

# Optional: USB webcam index when picamera2 not used (0, 1, 2...)
# CV2_CAMERA_INDEX=1

# Disable vision when no camera (ei kameraa)
# DISABLE_VISION=1
