# Copy this file to .env and fill in your values.
# .env is in .gitignore – never commit real keys.
#
# On Raspberry Pi: copy to .env on the Pi and use Linux paths, e.g.:
#   YT_COOKIES_FILE=/home/pi/tres-robo/cookies.txt

# Required for LLM (OpenAI)
OPENAI_API_KEY=

# TTS: elevenlabs (oletus) tai google (ilmainen)
# TTS_PROVIDER=elevenlabs

# ElevenLabs (oletus) — vaatii API-avaimen ja voice ID:n
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Ilmainen vaihtoehto: TTS_PROVIDER=google (ei tarvitse API-avainta)

# Optional: ducking (musiikki hiljenee kun puhutaan). DUCK_VOLUME=38 = taustalla kuuluu
# DUCK_VOLUME=38

# Optional: äänilaitteen valinta (jos musiikki ei kuulu)
# mpv: AUDIO_DEVICE=alsa/default tai --audio-device=help listaa
# ffplay Windows: AUDIO_DEVICE=0 (laitteen indeksi, 0=oletus)
# AUDIO_DEVICE=

# Optional: YouTube Premium – path to cookies.txt (export from browser)
# Windows: YT_COOKIES_FILE=c:\path\to\Tres-Robo\cookies.txt
# Raspberry Pi: YT_COOKIES_FILE=/home/pi/tres-robo/cookies.txt
YT_COOKIES_FILE=

# Optional: 4-array microphone (ReSpeaker etc.)
# Linux: MIC_DEVICE=hw:2,0
# Windows: MIC_DEVICE=0 (oletus) tai numeerinen indeksi. python -m sounddevice listaa.
# MIC_CHANNELS=4
# MIC_SAMPLE_RATE=16000
# USE_DENOISER=0

# Optional: puheentunnistuksen säätö (botti kuulee paremmin)
# MIC_GAIN=1.5              # Mikrofonivahvistus (0.5–5.0). Kauempaa puhuttaessa kokeile 2.0–2.5.
# VAD_AGGRESSIVENESS=1      # 0=herkimmin, 1=tasapaino, 2=vähemmän taustamelua, 3=vahvin.
# VAD_FRAME_DURATION_MS=20  # VAD frame (10, 20, 30 ms). 20 = tarkempi.
# STT_LANGUAGE=fi           # Kielihint Whisperille (tyhjä=auto). fi/en/sv/de/fr/es.
# WAKE_DEBUG=1              # Diagnostiikka: miksi herätyssanat eivät osu (Segment, Whisper, kuultiin).

# Optional: USB webcam index when picamera2 not used (0, 1, 2...)
# CV2_CAMERA_INDEX=1

# Disable vision when no camera (ei kameraa)
# DISABLE_VISION=1
